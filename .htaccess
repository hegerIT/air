# AIR Protocol Configuration

# Handle .well-known requests
RewriteEngine On
RewriteCond %{REQUEST_URI} ^/\.well-known/air$
RewriteRule ^.*$ /.well-known/air [L]

# Default routing to api.php
RewriteCond %{REQUEST_URI} !^/(api\.php|data\.md|index\.html|\.well-known/)
RewriteRule ^.*$ /api.php [QSA,L]

# CORS Headers
Header always set Access-Control-Allow-Origin "*"
Header always set Access-Control-Allow-Methods "GET, OPTIONS"
Header always set Access-Control-Allow-Headers "Content-Type"

# JSON Content-Type for API
<Files "api.php">
    Header set Content-Type "application/json; charset=utf-8"
</Files>

# Cache Control
<FilesMatch "\.(json|md)$">
    Header set Cache-Control "public, max-age=3600"
</FilesMatch>

# Security Headers
Header always set X-Content-Type-Options nosniff
Header always set X-Frame-Options DENY